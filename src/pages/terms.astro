---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import { SITE_URL } from '../config';

const title = "Terms of Service | WordForge";
const description = "WordForge's terms of service. Use the tool at your own risk for personal, non-commercial purposes.";

const breadcrumbs = [
  { name: "Terms of Service", url: "/terms/" }
];
---

<Layout title={title} description={description} canonical={`${SITE_URL}/terms/`} breadcrumbs={breadcrumbs} noindex>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <!-- Breadcrumb HTML navigation -->
    <nav class="text-sm text-[var(--color-muted)] mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-[var(--color-foreground)] transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-[var(--color-foreground)]" aria-current="page">Terms of Service</li>
      </ol>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-foreground)] mb-6">Terms of Service</h1>
    <p class="text-sm text-[var(--color-muted)] mb-8">Last updated: June 2025</p>

    <div class="prose prose-sm max-w-none text-[var(--color-muted)] space-y-4">
      <p>
        By using WordForge, you agree to these terms. If you do not agree, please do not use the service.
      </p>

      <h2 class="text-lg font-semibold text-[var(--color-foreground)] mt-6">Use of the Service</h2>
      <p>
        WordForge is provided free of charge for personal, non-commercial use. You may use the tool to unscramble words for games, puzzles, and educational purposes.
      </p>

      <h2 class="text-lg font-semibold text-[var(--color-foreground)] mt-6">No Warranty</h2>
      <p>
        WordForge is provided "as is" without any warranty. We do not guarantee that the dictionary is complete, accurate, or up-to-date. Always verify critical words against official Scrabble or Words With Friends dictionaries before playing them in a competitive setting.
      </p>

      <h2 class="text-lg font-semibold text-[var(--color-foreground)] mt-6">Limitation of Liability</h2>
      <p>
        In no event shall WordForge be liable for any direct, indirect, incidental, or consequential damages arising from your use of the service.
      </p>

      <h2 class="text-lg font-semibold text-[var(--color-foreground)] mt-6">Changes</h2>
      <p>
        We may update these terms at any time. Continued use of the service after changes constitutes acceptance of the new terms.
      </p>

      <AdSlot slot="terms-page" />
    </div>
  </div>
</Layout>
