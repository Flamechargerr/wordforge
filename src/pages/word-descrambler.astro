---
import Layout from '../layouts/Layout.astro';
import Solver from '../components/Solver.tsx';
import AdSlot from '../components/AdSlot.astro';
import { SITE_URL } from '../config';

const title = "Word Descrambler — Descramble Letters Into Words";
const description = "The fastest word descrambler online. Descramble letters to find valid words for Scrabble, Wordscapes, and more. Highly optimized with zero ads.";
const canonical = `${SITE_URL}/word-descrambler/`;

const breadcrumbs = [
  { name: "Word Descrambler", url: "/word-descrambler/" }
];
---

<Layout title={title} description={description} canonical={canonical} breadcrumbs={breadcrumbs}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <!-- Breadcrumbs -->
    <nav class="text-sm text-[var(--color-muted)] mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-[var(--color-foreground)] transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-[var(--color-foreground)]" aria-current="page">Word Descrambler</li>
      </ol>
    </nav>
    
    {/* Hero Section */}
    <div class="text-center mb-12 sm:mb-16">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-white mb-6">
        Word Descrambler
      </h1>
      <p class="text-lg sm:text-xl text-[var(--color-muted)] max-w-2xl mx-auto leading-relaxed">
        Stuck with scrambled letters? Enter them below to instantly descramble them into every possible valid dictionary word.
      </p>
    </div>

    {/* Solver Island */}
    <section aria-label="Word descrambler tool" class="mb-16">
      <Solver client:only="preact" />
      <AdSlot slot="word-descrambler-below-solver" />
    </section>

    {/* What is a Word Descrambler? */}
    <section class="mt-16 sm:mt-20 panel p-6 sm:p-8" aria-label="About descrambling">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-[var(--color-foreground)]">What is a Word Descrambler?</h2>
      <p class="text-[var(--color-muted)] leading-relaxed mb-4">
        A <strong>word descrambler</strong> is an online helper tool designed to solve scrambled letter combinations. If you are playing games like TextTwist, Wordscapes, or Scrabble, you often receive a random heap of letters. A descrambler scans a reference database of words and returns all the valid English words you can form.
      </p>
      <p class="text-[var(--color-muted)] leading-relaxed">
        Unlike other descramblers that clutter your screen with ads and cookie notices, WordForge runs 100% locally in your web browser. This means your letters never leave your computer, the search is instantaneous, and the layout stays clean.
      </p>
    </section>

  </div>
</Layout>
