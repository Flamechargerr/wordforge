---
import Layout from '../../../layouts/Layout.astro';
import AdSlot from '../../../components/AdSlot.astro';
import { createClientDictionary } from '../../../lib/dictionary-client';
import { getWordsByLengthAndStartingLetter } from '../../../lib/solver';

import { SITE_URL } from '../../../config';

export function getStaticPaths() {
  const paths: { params: { n: string; letter: string } }[] = [];
  for (let n = 2; n <= 8; n++) {
    for (const letter of 'abcdefghijklmnopqrstuvwxyz') {
      paths.push({ params: { n: String(n), letter } });
    }
  }
  return paths;
}

const { n, letter } = Astro.params;
const numN = Number(n);
const lower = (letter ?? 'a').toLowerCase();
const upper = lower.toUpperCase();

const dictionary = await createClientDictionary();
const words = getWordsByLengthAndStartingLetter(dictionary, numN, lower);

const title = `${n}-Letter Words Starting With ${upper} | Scrabble Dictionary | WordForge`;
const description = `Complete list of ${n}-letter words starting with ${upper}. ${words.length} valid Scrabble and Words With Friends words.`;
const canonical = `${SITE_URL}/letter-words/${n}/${lower}/`;

const breadcrumbs = [
  { name: `Words Starting With ${upper}`, url: `/words-starting-with/${lower}/` },
  { name: `${n}-Letter Words`, url: `/letter-words/${n}/${lower}/` }
];
---

<Layout title={title} description={description} canonical={canonical} breadcrumbs={breadcrumbs}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <nav class="text-sm text-[var(--color-muted)] mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-[var(--color-foreground)] transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href={`/words-starting-with/${lower}/`} class="hover:text-[var(--color-foreground)] transition-colors">Words Starting With {upper}</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-[var(--color-foreground)]" aria-current="page">{n}-Letter Words</li>
      </ol>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-foreground)] mb-2">
      {n}-Letter Words Starting With <span class="text-[var(--color-accent)]">{upper}</span>
    </h1>
    <p class="text-[var(--color-muted)] mb-4">
      {words.length} valid {n}-letter Scrabble and Words With Friends words starting with {upper}
    </p>
    <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-8 max-w-2xl">
      Need a <strong>{n}-letter word starting with {upper}</strong> to win your game? This page lists every valid dictionary word of length {n} beginning with the letter {upper}. Perfect for scoring big in Scrabble, finding key moves in Words With Friends, or solving daily word puzzles. Find the points for each word to maximize your game strategy!
    </p>

    <!-- Length Navigation -->
    <div class="flex flex-wrap justify-center gap-2 mb-8">
      {Array.from({ length: 7 }, (_, i) => i + 2).map(len => (
        <a
          href={`/letter-words/${len}/${lower}/`}
          class={`px-3 py-1.5 rounded-lg font-medium text-sm transition-colors ${
            len === numN
              ? 'bg-[var(--color-accent)] text-white'
              : 'bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-muted)] hover:text-[var(--color-foreground)]'
          }`}
        >
          {len} Letters
        </a>
      ))}
    </div>

    <AdSlot slot="letter-words-above-grid" />

    <!-- Words Grid -->
    <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-5 shadow-sm">
      {words.length > 0 ? (
        <div class="flex flex-wrap gap-2">
          {words.map(word => (
            <a
              href={`/unscramble/${word}/`}
              class="px-3 py-2 bg-[var(--color-background)] hover:bg-[var(--color-accent-subtle)] border border-[var(--color-border)] hover:border-[var(--color-accent)] rounded-lg text-sm font-medium transition-colors uppercase tracking-wide text-[var(--color-foreground)]"
            >
              {word}
            </a>
          ))}
        </div>
      ) : (
        <p class="text-[var(--color-muted)] text-center py-8">No {n}-letter words found starting with {upper}.</p>
      )}
    </div>

    <!-- Letter Navigation for same length -->
    <div class="mt-8 pt-6 border-t border-[var(--color-border)]">
      <h3 class="text-sm font-bold text-[var(--color-foreground)] mb-4 text-center">Browse other {n}-letter words starting with:</h3>
      <div class="flex flex-wrap justify-center gap-1.5">
        {'abcdefghijklmnopqrstuvwxyz'.split('').map(l => (
          <a
            href={`/letter-words/${n}/${l}/`}
            class={`w-8 h-8 flex items-center justify-center rounded-lg font-semibold text-xs transition-colors ${
              l === lower
                ? 'bg-[var(--color-accent)] text-white'
                : 'bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:border-[var(--color-accent)] shadow-sm'
            }`}
          >
            {l.toUpperCase()}
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
