---
import Layout from '../layouts/Layout.astro';
import Solver from '../components/Solver.tsx';

const title = "WordForge — Unscramble Any Letters Into Valid Words";
const description = "The fastest word unscrambler on the internet. Enter scrambled letters and instantly discover every valid Scrabble and Words With Friends word. 370,000+ word dictionary, zero ads, instant results.";
---

<Layout title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12 sm:py-20">
    
    {/* Hero Section */}
    <div class="text-center mb-12 sm:mb-16">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-white mb-6">
        WordForge Unscrambler
      </h1>
      <p class="text-lg sm:text-xl text-[var(--color-muted)] max-w-2xl mx-auto leading-relaxed">
        Enter up to 12 scrambled letters to instantly find all valid Scrabble and Words With Friends words.
      </p>
    </div>

    {/* Solver Island */}
    <section aria-label="Word unscrambler tool" class="mb-16">
      <Solver client:only="preact" />
    </section>

    {/* Features */}
    <section class="mt-16 sm:mt-20 grid grid-cols-1 sm:grid-cols-3 gap-6" aria-label="Features">
      <div class="panel p-6 text-center">
        <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3 class="text-lg font-bold text-[var(--color-foreground)] mb-2">Lightning Fast</h3>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">Sub-100ms response times. Words appear in real-time as you type — no search button needed.</p>
      </div>
      <div class="panel p-6 text-center">
        <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </div>
        <h3 class="text-lg font-bold text-[var(--color-foreground)] mb-2">Scrabble Scores</h3>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">Every word displays its official tile score. Easily find the highest-scoring moves.</p>
      </div>
      <div class="panel p-6 text-center">
        <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        </div>
        <h3 class="text-lg font-bold text-[var(--color-foreground)] mb-2">370,000+ Words</h3>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">Comprehensive dictionary mapping valid words for Scrabble, WWF, and anagram solver puzzles.</p>
      </div>
    </section>

    {/* SEO Content: What is a word unscrambler? */}
    <section class="mt-16 sm:mt-20 panel p-6 sm:p-8" aria-label="About word unscramblers">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-[var(--color-foreground)]">What is a Word Unscrambler?</h2>
      <p class="text-[var(--color-muted)] leading-relaxed mb-4">
        A <strong>word unscrambler</strong> is a utility that takes scrambled letters and checks them against a dictionary to find every valid word. If you are stuck playing Scrabble, Words With Friends, or simply working on an anagram puzzle, a solver helps you see all possible moves instantly.
      </p>
      <p class="text-[var(--color-muted)] leading-relaxed">
        WordForge runs a state-of-the-art <strong>sorted-key algorithm</strong> locally in your web browser. Instead of sending requests back and forth to a server, we search the entire dictionary in less than 10 milliseconds. Zero delay, zero tracking, zero distraction.
      </p>
    </section>

    {/* How to Use */}
    <section class="mt-16 sm:mt-20 px-2" aria-label="How to use WordForge">
      <h2 class="text-2xl sm:text-3xl font-bold mb-8 text-[var(--color-foreground)]">How to Use WordForge</h2>
      <ol class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        <li class="flex flex-col gap-3">
          <span class="w-10 h-10 rounded-xl bg-[var(--color-accent)] text-white flex items-center justify-center font-bold text-base shadow-sm">1</span>
          <div>
            <h4 class="font-bold text-lg text-[var(--color-foreground)] mb-1">Enter your letters</h4>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">Type your scrambled letters in the search bar. Results appear immediately as you type.</p>
          </div>
        </li>
        <li class="flex flex-col gap-3">
          <span class="w-10 h-10 rounded-xl bg-[var(--color-accent)] text-white flex items-center justify-center font-bold text-base shadow-sm">2</span>
          <div>
            <h4 class="font-bold text-lg text-[var(--color-foreground)] mb-1">Browse and sort</h4>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">Words are grouped by length. Each word shows its tile value for strategic play.</p>
          </div>
        </li>
        <li class="flex flex-col gap-3">
          <span class="w-10 h-10 rounded-xl bg-[var(--color-accent)] text-white flex items-center justify-center font-bold text-base shadow-sm">3</span>
          <div>
            <h4 class="font-bold text-lg text-[var(--color-foreground)] mb-1">Click to copy</h4>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">Click any word tile to copy it to your clipboard. Paste it directly into your game.</p>
          </div>
        </li>
      </ol>
    </section>

    {/* Popular Searches */}
    <section class="mt-16 sm:mt-20" aria-label="Popular searches">
      <h2 class="text-2xl font-bold mb-6 text-[var(--color-foreground)]">Popular Searches</h2>
      <div class="flex flex-wrap gap-2.5">
        {['listen', 'triangle', 'silent', 'anagram', 'scramble', 'letters', 'words', 'friends', 'scrabble', 'solver'].map((word) => (
          <a
            href={`/unscramble/${word}/`}
            class="px-4 py-2 bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent-subtle)] rounded-xl text-sm font-semibold text-[var(--color-muted)] transition-all duration-150 shadow-sm"
          >
            Unscramble {word}
          </a>
        ))}
      </div>
    </section>

    {/* FAQ Section */}
    <section class="mt-16 sm:mt-20" aria-label="Frequently asked questions">
      <h2 class="text-2xl sm:text-3xl font-bold mb-8 text-[var(--color-foreground)]">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="group bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl">
          <summary class="px-5 py-4 font-medium text-[var(--color-foreground)] cursor-pointer list-none flex items-center justify-between">
            How many words can WordForge find?
            <span class="text-[var(--color-muted)] group-open:rotate-180 transition-transform">&#9662;</span>
          </summary>
          <div class="px-5 pb-4 text-[var(--color-muted)] text-sm leading-relaxed">
            WordForge's dictionary contains over 370,000 valid English words. From a typical 6-letter input like "listen", we find 30+ words ranging from 2 to 6 letters long. From 8 letters like "triangle", we find 600+ words.
          </div>
        </details>
        <details class="group bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl">
          <summary class="px-5 py-4 font-medium text-[var(--color-foreground)] cursor-pointer list-none flex items-center justify-between">
            Is WordForge free?
            <span class="text-[var(--color-muted)] group-open:rotate-180 transition-transform">&#9662;</span>
          </summary>
          <div class="px-5 pb-4 text-[var(--color-muted)] text-sm leading-relaxed">
            Yes, WordForge is completely free. No signup, no download, no ads, no paywall. We believe word tools should be accessible to everyone.
          </div>
        </details>
        <details class="group bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl">
          <summary class="px-5 py-4 font-medium text-[var(--color-foreground)] cursor-pointer list-none flex items-center justify-between">
            Can I use this for Scrabble and Words With Friends?
            <span class="text-[var(--color-muted)] group-open:rotate-180 transition-transform">&#9662;</span>
          </summary>
          <div class="px-5 pb-4 text-[var(--color-muted)] text-sm leading-relaxed">
            Absolutely. WordForge is perfect for Scrabble and Words With Friends. Every result shows the standard Scrabble tile score, and you can sort by score to find the highest-value plays. Our dictionary covers the most common English words used in word games.
          </div>
        </details>
        <details class="group bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl">
          <summary class="px-5 py-4 font-medium text-[var(--color-foreground)] cursor-pointer list-none flex items-center justify-between">
            How fast is the solver?
            <span class="text-[var(--color-muted)] group-open:rotate-180 transition-transform">&#9662;</span>
          </summary>
          <div class="px-5 pb-4 text-[var(--color-muted)] text-sm leading-relaxed">
            Our sorted-key algorithm solves in under 100 milliseconds, even for 12-letter inputs. The entire solver runs client-side in your browser, so there is no server delay and no network request.
          </div>
        </details>
      </div>
    </section>

  </div>
</Layout>
