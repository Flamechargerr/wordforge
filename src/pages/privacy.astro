---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import { SITE_URL } from '../config';

const title = "Privacy Policy | WordForge";
const description = "WordForge's privacy policy. We do not collect personal data, use cookies, or track you across the web.";

const breadcrumbs = [
  { name: "Privacy Policy", url: "/privacy/" }
];
---

<Layout title={title} description={description} canonical={`${SITE_URL}/privacy/`} breadcrumbs={breadcrumbs} noindex>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <!-- Breadcrumb HTML navigation -->
    <nav class="text-sm text-[var(--color-muted)] mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-[var(--color-foreground)] transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-[var(--color-foreground)]" aria-current="page">Privacy Policy</li>
      </ol>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-foreground)] mb-6">Privacy Policy</h1>
    <p class="text-sm text-[var(--color-muted)] mb-8">Last updated: June 2025</p>

    <div class="prose prose-sm max-w-none text-[var(--color-muted)] space-y-4">
      <p>
        WordForge is committed to protecting your privacy. This policy explains what information we collect and how we use it.
      </p>

      <h2 class="text-lg font-semibold text-[var(--color-foreground)] mt-6">What We Do Not Collect</h2>
      <ul class="list-disc pl-5 space-y-1">
        <li>We do not collect personal information (name, email, address, etc.).</li>
        <li>We do not use cookies or tracking pixels.</li>
        <li>We do not share data with third-party advertisers.</li>
        <li>We do not use analytics that fingerprint your device.</li>
      </ul>

      <h2 class="text-lg font-semibold text-[var(--color-foreground)] mt-6">What We Do Collect</h2>
      <p>
        We log anonymous, aggregated usage metrics (e.g., how many searches were performed in a day) to help us understand how the tool is used and identify performance issues. This data cannot be used to identify individual users.
      </p>

      <h2 class="text-lg font-semibold text-[var(--color-foreground)] mt-6">Data Storage</h2>
      <p>
        The word unscrambler runs entirely in your browser. The dictionary is loaded locally and your search letters are never sent to our servers.
      </p>

      <h2 class="text-lg font-semibold text-[var(--color-foreground)] mt-6">Changes</h2>
      <p>
        If we make material changes to this policy, we will update the date at the top of this page.
      </p>

      <AdSlot slot="privacy-page" />
    </div>
  </div>
</Layout>
