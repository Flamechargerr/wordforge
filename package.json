{
  "name": "wordforge",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npx tsx scripts/build-dictionary.ts && astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "astro": "astro",
    "lint": "eslint src --ext .astro,.ts,.tsx",
    "postinstall": "npx tsx scripts/build-dictionary.ts"
  },
  "dependencies": {
    "@astrojs/preact": "^6.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.2",
    "preact": "^10.29.2",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "vitest": "^4.1.9"
  }
}
